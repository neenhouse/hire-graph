    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "wrangler": "^4.79.0"
  }
}
