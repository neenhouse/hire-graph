    "build": "tsc --noEmit && vite build",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@cloudflare/containers": "^0.2.2",
    "react": "^19.0.0",
